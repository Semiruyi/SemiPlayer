{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-all",
      "displayName": "Windows UCRT64 Ninja (DLL + tests + smoke host)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-windows",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SEMI_BUILD_DLL": "ON",
        "SEMI_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-all", "configurePreset": "windows-all" }
  ]
}
